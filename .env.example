# ===== MySQL =====
MYSQL_ROOT_PASSWORD=change_root_password
MYSQL_DATABASE=nhom8_db
MYSQL_USER=nhom8_user
MYSQL_PASSWORD=change_app_password

# ===== Spring Boot Database =====
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/nhom8_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=nhom8_user
SPRING_DATASOURCE_PASSWORD=change_app_password

# ===== JWT =====
APP_JWT_SECRET=replace_with_a_long_random_secret
APP_JWT_EXPIRATION_MS=86400000

# ===== CORS =====
APP_CORS_ALLOWED_ORIGINS=https://alexdev.software,https://www.alexdev.software

# ===== Feature Flags =====
# Set to false on production to disable AI services (saves ~4GB RAM)
APP_FEATURES_VECTOR_SEARCH_ENABLED=false
APP_FEATURES_AI_CHAT_ENABLED=false

# ===== VNPay =====
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET
VNPAY_BASE_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_VERSION=2.1.0
VNPAY_COMMAND=pay
VNPAY_CURR_CODE=VND
VNPAY_LOCALE=vn
VNPAY_RETURN_URL=https://alexdev.software/api/payment/vnpay-callback

# ===== Email =====
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=YOUR_EMAIL@gmail.com
SPRING_MAIL_PASSWORD=YOUR_APP_PASSWORD
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Qdrant (only needed if vector search enabled) =====
QDRANT_URL=http://qdrant:6335
QDRANT_COLLECTION=manga
QDRANT_EMBED_DIM=768

# ===== Ollama (only needed if AI chat enabled) =====
OLLAMA_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ===== Frontend =====
VITE_API_URL=/api
VITE_WS_URL=/ws
VITE_ENABLE_AI_CHAT=false
VITE_ENABLE_VECTOR_SEARCH=false

# ===== JVM =====
JAVA_OPTS=-Xms256m -Xmx1024m